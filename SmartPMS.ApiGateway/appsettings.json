{
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/gateway/auth/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/auth/{**catch-all}"
          }
        ]
      },

      "employee-list-route": {
        "ClusterId": "employee-cluster",
        "Match": {
          "Path": "/gateway/employees"
        },
        "Transforms": [
          {
            "PathSet": "/api/employees"
          }
        ]
      },

      "employee-route": {
        "ClusterId": "employee-cluster",
        "Match": {
          "Path": "/gateway/employees/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/employees/{**catch-all}"
          }
        ]
      },

      "performance-plan-list-route": {
        "ClusterId": "performance-plan-cluster",
        "Match": {
          "Path": "/gateway/performanceplans"
        },
        "Transforms": [
          {
            "PathSet": "/api/performanceplans"
          }
        ]
      },

      "performance-plan-route": {
        "ClusterId": "performance-plan-cluster",
        "Match": {
          "Path": "/gateway/performanceplans/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/performanceplans/{**catch-all}"
          }
        ]
      }
    },

    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity-destination": {
            "Address": "https://localhost:7024/"
          }
        }
      },

      "employee-cluster": {
        "Destinations": {
          "employee-destination": {
            "Address": "https://localhost:7158/"
          }
        }
      },

      "performance-plan-cluster": {
        "Destinations": {
          "performance-plan-destination": {
            "Address": "https://localhost:7216/"
          }
        }
      }
    }
  },

  "AllowedHosts": "*"
}